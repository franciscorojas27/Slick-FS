{
    "icon": "/assets/icon.png",
    "name": "slick-fs",
    "displayName": "Slick FS",
    "description": "Edita tu sistema de archivos como si fuera un buffer de texto. Crea, renombra y organiza directorios usando solo el teclado, multicursores y autocompletado.",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:slick-fs.oil",
        "onCommand:slick-fs.createPath",
        "onCommand:slick-fs.renamePath",
        "onCommand:slick-fs.deletePath"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "slick-fs.oil",
                "title": "Slick FS: Operaciones rápidas"
            },
            {
                "command": "slick-fs.createPath",
                "title": "Slick FS: Crear ruta"
            },
            {
                "command": "slick-fs.renamePath",
                "title": "Slick FS: Renombrar ruta"
            },
            {
                "command": "slick-fs.deletePath",
                "title": "Slick FS: Eliminar ruta"
            },
            {
                "command": "slick-fs.navigateFolders",
                "title": "Slick FS: Navegar carpetas"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "pnpm run package",
        "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/vscode": "^1.110.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "typescript-eslint": "^8.56.1",
        "eslint": "^9.39.3",
        "esbuild": "^0.27.3",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2"
    }
}